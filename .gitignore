# ─────────────────────────────────────────────────────────────
# Secrets & runtime state — NEVER commit (public repo)
# ─────────────────────────────────────────────────────────────
# TLS material, validator keys, keystores
*.p12
*.jks
*.key
*.pem
*.keystore
**/certs/
truststore.p12

# SSH wrappers — contain droplet root password / host keys
*.bat

# Nested repo (has its own remote: someamount2190/phantomchain-node)
src/pc-node-repo/

# Node runtime data / chain state / per-node dirs
src/node/node-data*/
src/node/ph[0-9]*/
src/node/testnet/
src/node/tn[0-9]*/
src/node/join/
src/node/live/
src/node/bt/
**/pcdata/

# Scratch: UI dumps, cert-chain captures, stray text logs
**/ui*.xml
**/chain.txt
**/*log.txt
**/log.txt
chain.json
votes*.json
node-*.json

# ─────────────────────────────────────────────────────────────
# Build outputs & vendored toolchains (regenerable)
# ─────────────────────────────────────────────────────────────
**/build/
**/out/
**/.gradle/
src/android/gradle-dist/
src/deploy/
src/lib/
src/sim/
src/node/node-data*/
src/node/pcdata*/
*.apk
*.dex
*.class

# VM disk images & artifacts (~1.2 GB)
src/vm/*.qcow2
src/vm/*.img
src/vm/*.iso
src/vm/serial.log

# ─────────────────────────────────────────────────────────────
# Machine-specific config, logs, scratch, generated media
# ─────────────────────────────────────────────────────────────
local.properties
*.log
*.out
*.err
**/yes.txt
**/no.txt
**/ui.xml
*.png
